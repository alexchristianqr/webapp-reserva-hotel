# ======================================================================================
# deploy.env.example — Variables para scripts/deploy.sh
#
# Copia este archivo a scripts/deploy.env y rellena los valores reales:
#   cp scripts/deploy.env.example scripts/deploy.env
#
# scripts/deploy.env NO debe versionarse (contiene el token de GitHub). El .gitignore
# ya lo excluye. El entorno del shell tiene prioridad sobre este archivo.
# ======================================================================================

# --- Comunes -------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=                       # opcional; vacío usa el perfil por defecto
ENV=dev                            # dev | qa | prod
STACK_PREFIX=reserva-hotel         # prefijo de los nombres de stack (reserva-hotel-<paso>-<env>)
REPO_NAME=webapp-reserva-hotel     # nombre base del repo ECR (la plantilla añade -<env>)
IMAGE_TAG=latest                   # etiqueta de la imagen Docker a publicar/desplegar

# --- Red (step_02: net-stack) --------------------------------------------------------
VPC_ID=vpc-xxxxxxxx                # VPC existente donde desplegar
PUBLIC_SUBNET_IDS=subnet-aaaa,subnet-bbbb   # subredes públicas para el ALB (>=2 AZ)
PRIVATE_SUBNET_IDS=subnet-cccc,subnet-dddd  # subredes privadas para las tareas ECS
LISTENER_PORT=80                   # puerto público del ALB (HTTP)
CONTAINER_PORT=8080                # puerto del contenedor Tomcat

# --- Base de datos (step_03: db-stack) -----------------------------------------------
DB_SUBNET_IDS=subnet-cccc,subnet-dddd  # subredes (privadas) del DB Subnet Group (>=2 AZ)
DB_NAME=db_hotel                   # nombre de la base de datos inicial
DB_USERNAME=admin                  # usuario maestro de RDS (la clave la gestiona Secrets Manager)
DB_INSTANCE_CLASS=db.t3.micro      # clase de instancia RDS
ALLOCATED_STORAGE=20               # almacenamiento en GB

# --- App / ECS (step_04: app-stack) --------------------------------------------------
ECS_CLUSTER_NAME=reserva-hotel-cluster  # clúster ECS (se crea si no existe)
CPU=512                            # 256 | 512 | 1024 | 2048 | 4096
MEMORY=1024                        # 512 | 1024 | 2048 | 3072 | 4096 | ...
DESIRED_COUNT=1                    # número de tareas ECS deseadas

# --- CI/CD (step_05: cicd-stack) -----------------------------------------------------
GITHUB_OWNER=alexchristianqr       # propietario del repositorio en GitHub
GITHUB_BRANCH=main                 # rama a desplegar
GITHUB_TOKEN=                      # ghp_xxx — token con permiso de lectura. ¡NO commitear!
